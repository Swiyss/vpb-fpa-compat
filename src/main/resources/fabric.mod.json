{
  "schemaVersion": 1,
  "id": "vpb_fpa_compat",
  "version": "${version}",
  "name": "VPB Fresh Player Animations Compat",
  "description": "Client-side detection and debug foundation for Vic's Point Blank plus Fresh Player Animations compatibility.",
  "authors": [
    "joao2"
  ],
  "license": "All-Rights-Reserved",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.joao2.vpbfpa.VpbFpaCompatClient"
    ]
  },
  "mixins": [
    "vpb_fpa_compat.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "pointblank": "*",
    "entity_model_features": "*",
    "entity_texture_features": "*",
    "notenoughanimations": "*",
    "iris": "*",
    "sodium": "*"
  }
}
